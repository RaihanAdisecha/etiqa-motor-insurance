# ==========================================================
# Environment Variables - Etiqa Motor Vehicle Insurance API
# ==========================================================
# Salin file ini menjadi ".env" untuk local development,
# atau set nilai-nilai ini di dashboard Railway (Variables tab)
# untuk deployment production.

# ----------------------------------------------------------
# Database (Supabase PostgreSQL)
# ----------------------------------------------------------
# Ambil connection string dari Supabase:
# Project Settings -> Database -> Connection string -> URI
# Format: postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/postgres
DATABASE_URL=postgresql://postgres:your_password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ----------------------------------------------------------
# Aplikasi
# ----------------------------------------------------------
APP_NAME=Etiqa Motor Vehicle Insurance API
APP_VERSION=1.0.0
DEBUG=False

# ----------------------------------------------------------
# CORS
# ----------------------------------------------------------
# Daftar origin frontend yang diizinkan mengakses API ini.
# Pisahkan dengan koma jika lebih dari satu, contoh:
# CORS_ORIGINS=["https://etiqa-mvi-frontend.vercel.app","http://localhost:5500"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:5500","http://127.0.0.1:5500","http://127.0.0.1:3000"]

# ----------------------------------------------------------
# Business Rule: Format Nomor Polisi
# ----------------------------------------------------------
POLICY_NUMBER_PREFIX=ETQ
POLICY_NUMBER_YEAR=2026
POLICY_NUMBER_SEQUENCE_DIGITS=6