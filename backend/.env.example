# ==========================================================
# Environment Variables - Etiqa Motor Vehicle Insurance API
# ==========================================================
# Copy this file to ".env" for local development,
# or configure these variables in the Railway dashboard
# (Variables tab) for production deployment.

# ----------------------------------------------------------
# Database (Supabase PostgreSQL)
# ----------------------------------------------------------
# Obtain the connection string from:
# Supabase Dashboard -> Project Settings -> Database
#
# Format:
# postgresql://postgres:<YOUR_PASSWORD>@<YOUR_HOST>:5432/postgres
DATABASE_URL=postgresql://postgres:<YOUR_PASSWORD>@<YOUR_HOST>:5432/postgres

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------
APP_NAME=Etiqa Motor Vehicle Insurance API
APP_VERSION=1.0.0
DEBUG=False

# ----------------------------------------------------------
# CORS
# ----------------------------------------------------------
# Allowed frontend origins.
#
# Example (development):
# CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500"]
#
# Example (production):
# CORS_ORIGINS=["https://your-project.vercel.app"]
CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500"]

# ----------------------------------------------------------
# Policy Number Configuration
# ----------------------------------------------------------
POLICY_NUMBER_PREFIX=ETQ
POLICY_NUMBER_YEAR=2026
POLICY_NUMBER_SEQUENCE_DIGITS=6